# PostgreSQL — Railway managed (never use Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/chatbox

# Redis — Railway managed
REDIS_URL=redis://localhost:6379

# AES-256-GCM master key for all per-bot credentials and message content (32 bytes base64)
FIELD_ENCRYPTION_KEY=<run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))">

# HMAC-SHA256 pepper for phone number hashes — required in production
# Prevents dictionary attacks against the low-entropy phone number space
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_HASH_SECRET=<run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# Platform-controlled safety classifier (NOT a client LLM key)
SAFETY_PROVIDER_API_KEY=

# Meta / WhatsApp
META_APP_SECRET=
META_APP_ID=          # Required for Embedded Signup channel provisioning
META_API_VERSION=v21.0
WEBHOOK_VERIFY_TOKEN=<random-secret-min-32-chars>

# Auth — minimum 32 characters required
ADMIN_API_KEY=<run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
JWT_SECRET=<run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
JWT_ISSUER=chatbox-api
JWT_AUDIENCE=chatbox-clients

POLICY_VERSION=1.0

PORT=3000
NODE_ENV=development
