generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String   @id @default(uuid())
  name               String
  plan               String   @default("free") // 'free' | 'pro' | 'enterprise'
  msgQuota           Int      @default(1000) @map("msg_quota") // 0 = unlimited
  msgUsed            Int      @default(0) @map("msg_used")
  currentPeriodStart DateTime @default(now()) @map("current_period_start")
  sentryDsnEnc       Bytes?   @map("sentry_dsn_enc") // AES-256-GCM encrypted; null = tenant Sentry disabled
  createdAt          DateTime @default(now()) @map("created_at")

  orgUsers   OrgUser[]
  bots       Bot[]
  skills     Skill[]
  loopStates LoopState[]
  solicitudes Solicitud[]

  @@map("organizations")
}

model OrgUser {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  email        String   @unique
  role         String   // 'owner' | 'admin' | 'editor'
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id])

  @@map("org_users")
}

// Core entity — every row is a complete chatbot. Config only, no code.
model Bot {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  name          String
  status        String   @default("draft") // 'draft' | 'active' | 'paused' | 'credential_error'
  locale        String   @default("es-MX")
  systemPrompt  String?  @map("system_prompt")
  identity      Json?
  onboardingMsg String?  @map("onboarding_msg")
  historyWindow Int      @default(5) @map("history_window")
  // LLM chosen by the client — credentials supplied by client, encrypted
  llmProvider   String?  @map("llm_provider") // 'anthropic' | 'openai' | 'google' | 'mistral' | ...
  llmModel      String?  @map("llm_model")
  llmApiKeyEnc  Bytes?   @map("llm_api_key_enc") // AES-256-GCM encrypted
  llmParams     Json?    @map("llm_params")
  safetyLevel   String   @default("standard") @map("safety_level") // 'strict' | 'standard' | 'minimal'
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  org            Organization       @relation(fields: [orgId], references: [id])
  branding       BotBranding?
  promptVersions BotPromptVersion[]
  commands       BotCommand[]
  knowledge      BotKnowledge[]
  crisisConfig   BotCrisisConfig[]
  channels       Channel[]
  integrations   BotIntegration[]
  endUsers       EndUser[]
  messages       Message[]
  crisisEvents   CrisisEvent[]
  solicitudes    Solicitud[]

  @@map("bots")
}

model BotBranding {
  id               String  @id @default(uuid())
  botId            String  @unique @map("bot_id")
  companyName      String? @map("company_name")
  logoUrl          String? @map("logo_url")
  primaryColor     String? @map("primary_color")
  website          String?
  supportContact   String? @map("support_contact")
  privacyPolicyUrl String? @map("privacy_policy_url")
  termsUrl         String? @map("terms_url")

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("bot_branding")
}

model BotPromptVersion {
  id           String   @id @default(uuid())
  botId        String   @map("bot_id")
  version      Int
  systemPrompt String   @map("system_prompt")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("bot_prompt_versions")
}

model BotCommand {
  id           String @id @default(uuid())
  botId        String @map("bot_id")
  trigger      String
  responseType String @map("response_type") // 'static' | 'action'
  payload      Json

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, trigger])
  @@map("bot_commands")
}

model BotKnowledge {
  id            String   @id @default(uuid())
  botId         String   @map("bot_id")
  title         String
  content       String
  tags          String[]
  embeddingData Bytes?   @map("embedding_data") // Float32Array — cosine similarity, no pgvector needed
  hasEmbedding  Boolean  @default(false) @map("has_embedding")

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("bot_knowledge")
}

model BotCrisisConfig {
  id      String  @id @default(uuid())
  botId   String  @map("bot_id")
  country String
  lines   Json    // [{name, phone, hours}]
  enabled Boolean @default(true)

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("bot_crisis_config")
}

model Channel {
  id          String @id @default(uuid())
  botId       String @map("bot_id")
  provider    String // 'meta_cloud' | 'embedded_signup' | 'bsp_*'
  phoneId     String @map("phone_id")
  credentials Bytes  // AES-256-GCM encrypted JSON {accessToken, businessAccountId}
  verifyToken String @map("verify_token")
  status      String @default("pending") // 'connected' | 'pending' | 'error'

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([phoneId])
  @@map("channels")
}

model BotIntegration {
  id          String @id @default(uuid())
  botId       String @map("bot_id")
  kind        String // 'stt' | ...
  provider    String
  credentials Bytes  // AES-256-GCM encrypted JSON
  status      String @default("active")

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("bot_integrations")
}

model EndUser {
  id               String   @id @default(uuid())
  botId            String   @map("bot_id")
  waPhoneHash      String   @map("wa_phone_hash") // HMAC-SHA256(phone, PHONE_HASH_SECRET) — never stored in clear
  locale           String?
  paused           Boolean  @default(false)
  consentDeclined  Boolean  @default(false) @map("consent_declined")
  createdAt        DateTime @default(now()) @map("created_at")

  bot          Bot           @relation(fields: [botId], references: [id], onDelete: Cascade)
  consents     Consent[]
  messages     Message[]
  crisisEvents CrisisEvent[]
  feedback     Feedback[]

  @@unique([botId, waPhoneHash])
  @@map("end_users")
}

model Consent {
  id            String   @id @default(uuid())
  endUserId     String   @map("end_user_id")
  botId         String   @map("bot_id")
  acceptedAt    DateTime @default(now()) @map("accepted_at")
  policyVersion String   @map("policy_version")

  endUser EndUser @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@map("consents")
}

model Message {
  id         String   @id @default(uuid())
  botId      String   @map("bot_id")
  endUserId  String   @map("end_user_id")
  direction  String   // 'in' | 'out'
  inputType  String   @map("input_type") // 'text' | 'voice' | 'interactive'
  bodyEnc    Bytes    @map("body_enc") // AES-256-GCM encrypted
  externalId String?  @unique @map("external_id") // WA message_id for idempotency — nullable unique (PostgreSQL allows multiple NULLs)
  createdAt  DateTime @default(now()) @map("created_at")

  bot      Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)
  endUser  EndUser    @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  feedback Feedback[]

  @@index([botId, endUserId, createdAt])
  @@map("messages")
}

model CrisisEvent {
  id          String   @id @default(uuid())
  botId       String   @map("bot_id")
  endUserId   String   @map("end_user_id")
  detectedAt  DateTime @default(now()) @map("detected_at")
  category    String
  actionTaken String   @map("action_taken")

  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  endUser EndUser @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@map("crisis_events")
}

model Feedback {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  endUserId String   @map("end_user_id")
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  endUser EndUser @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

model AuditLog {
  id         String   @id @default(uuid())
  orgId      String?  @map("org_id")
  actorId    String?  @map("actor_id")
  actorRole  String?  @map("actor_role")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

// Skills generados por cliente vía FACTORY.
// Los skills base (forge-intake, forge-sources, etc.) viven en el repo (src/forge/skills/),
// no en esta tabla. Esta tabla es solo para contenido generado que pertenece a una org.
model Skill {
  id                    String    @id @default(uuid())
  orgId                 String    @map("org_id")
  name                  String    // kebab-case; único dentro de la org por versión
  version               Int       @default(1)
  content               String    // SKILL.md completo (el prompt que carga el LLM)
  validators            Json?     // refs a validadores asociados: [{name, script}]
  verboCentral          String    @map("verbo_central") // 'reusar' | 'modificar' | 'fabricar'
  nivelGeneralizacion   String    @default("cliente") @map("nivel_generalizacion") // 'cliente' | 'vertical' | 'universal'
  forgeApproved         Boolean   @default(false) @map("forge_approved")
  requiereRevisionHumana Boolean  @default(false) @map("requiere_revision_humana")
  approvedAt            DateTime? @map("approved_at")
  approvedBy            String?   @map("approved_by") // OrgUser.id del aprobador
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, name, version])
  @@index([orgId])
  @@map("skills")
}

// Solicitud de operación Forge.
// Registra el ciclo de vida de una petición: problema NL → pipeline → skill/loop.
model Solicitud {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  botId          String   @map("bot_id")
  problema       String
  estado         String   @default("pendiente") // 'pendiente'|'procesando'|'completado'|'error'
  fichaJson      Json?    @map("ficha_json")
  planJson       Json?    @map("plan_json")
  extraccionJson Json?    @map("extraccion_json")
  encargoJson    Json?    @map("encargo_json")
  skillId        String?  @map("skill_id")
  loopId         String?  @map("loop_id")
  errorDetalle   String?  @map("error_detalle")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id])
  bot Bot          @relation(fields: [botId], references: [id])

  @@index([orgId, createdAt])
  @@index([estado])
  @@map("solicitudes")
}

// Estado persistente del lazo continuo forge-loop.
// Un lazo es un estado en reposo que el scheduler despierta en ráfagas.
// El acceso a un registro debe usar SELECT … FOR UPDATE SKIP LOCKED para
// evitar ejecuciones concurrentes del mismo lazo.
model LoopState {
  loopId                  String    @id @map("loop_id") // asignado por la aplicación
  fichaId                 String    @map("ficha_id")    // id de la ficha forge-intake de origen
  orgId                   String    @map("org_id")
  ritmo                   Json      // {tipo:'cron'|'umbral', valor?:string, metrica?:string, operador?:string, valor_umbral?:number}
  estadoOperativo         String    @default("activo") @map("estado_operativo") // 'activo'|'pausado'|'adaptando'|'detenido'
  ultimaEjecucion         DateTime? @map("ultima_ejecucion")
  proximaEjecucion        DateTime? @map("proxima_ejecucion") // indexado: el scheduler filtra aquí
  ejecucionesTotales      Int       @default(0) @map("ejecuciones_totales")
  huellaAnterior          Json?     @map("huella_anterior")       // {contenido_hash, cobertura_pct, fuentes_activas}
  skillOperante           Json      @map("skill_operante")         // {name:string, version:number, approved_at:string}
  fallosConsecutivos      Int       @default(0) @map("fallos_consecutivos")
  ultimaAnomalia          Json?     @map("ultima_anomalia")        // {tipo, detalle, ts}
  pendienteAprobacion     Boolean   @default(false) @map("pendiente_aprobacion")
  politicaAdaptacion      Json      @map("politica_adaptacion")   // {adaptar_si, no_adaptar_si, max_adaptaciones_por_periodo, periodo_horas, extraccion_vacia_es_fallo}
  cooldownAdaptacionHasta DateTime? @map("cooldown_adaptacion_hasta")
  adaptacionesEnPeriodo   Json      @default("{}") @map("adaptaciones_en_periodo") // {periodo_inicio:string, count:number}
  historial               Json      @default("[]") // [{ts, evento, detalle}]
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id])

  // Índice clave para el scheduler: lista lazos activos cuya próxima ejecución ya pasó
  @@index([estadoOperativo, proximaEjecucion])
  @@index([orgId])
  @@map("loop_states")
}
