{
  "name": "nodematik",
  "version": "0.1.0",
  "description": "Nodematik — Operador autónomo de soluciones. Convierte un problema en lenguaje natural en una capacidad operada: intake → sources → extract → analyze → factory → gate → loop.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node dist/migrate.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "@sentry/node": "^10.56.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
