{
  "name": "chatbox",
  "version": "0.1.0",
  "description": "Multi-bot WhatsApp chatbot platform — multi-tenant, LLM-agnostic, BYO credentials",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.0",
    "fastify": "^4.28.1",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
